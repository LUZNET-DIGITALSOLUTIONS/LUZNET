  <script>
  
  //efecto div 1
    function prepararMatrixTexto() {
      const p = document.getElementById('matrix-text');
      if (!p) return;

      const texto = p.getAttribute('data-text');
      p.textContent = ''; // limpiar contenido

      // Crear spans para cada letra con retraso aleatorio
      for (let i = 0; i < texto.length; i++) {
        const span = document.createElement('span');
        span.textContent = texto[i];
        const delay = (Math.random() * 1.5).toFixed(2); // retraso aleatorio
        span.style.animationDelay = `${delay}s`;
        p.appendChild(span);
      }
    }

    // Observer para activar el efecto cada vez que el div1 entra en pantalla
    document.addEventListener("DOMContentLoaded", () => {
      const targetDiv = document.querySelector(".hijo1");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            prepararMatrixTexto();
          }
        });
      }, { threshold: 0.5 });

      observer.observe(targetDiv);
    });
    
    
    
  //efecto olas de mar div 2
  function prepararWaveTexto() {
    const p = document.getElementById('wave-text');
    if (!p) return;

    const texto = p.textContent;
    p.textContent = ''; // limpiar contenido

    // Crear spans para cada letra (incluyendo espacios)
    for (let i = 0; i < texto.length; i++) {
      const span = document.createElement('span');
      span.textContent = texto[i] === " " ? "\u00A0" : texto[i]; // espacio visible
      span.style.animationDelay = `${i * 0.2}s`; // efecto de ola progresivo
      p.appendChild(span);
    }
  }

  prepararWaveTexto();
  
  
  
