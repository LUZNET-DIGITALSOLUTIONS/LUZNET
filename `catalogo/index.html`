/* Estilo de la tabla dentro del div 2 */
.tabla-precios {
  background: rgba(0, 0, 0, 0.2);
  border: 1px solid white;
  height: 400px;
  border-radius: 12px;
  color: white;
  text-align: center;
  max-width: 95%;
  overflow-y: auto; /* scroll vertical */
  position: relative;

  /* estado inicial */
  transform: scale(0);
  opacity: 0;
}

/* barrita decorativa a la derecha */
.tabla-precios::after {
  content: "";
  position: absolute;
  top: 0;
  right: 0;
  width: 6px;
  height: 25%;
  background: linear-gradient(to bottom, black,black);
  animation: glowBar 2s infinite alternate;
}

/* animación suave */
@keyframes glowBar {
  from { opacity: 0.3; }
  to { opacity: 1; }
}

.tabla-precios table {
  width: 100%;
  border-collapse: collapse;
}

.tabla-precios th, .tabla-precios td {
  border: 1px solid white;
  font-size: 20px;
}

.tabla-precios th {
  background: rgba(0, 0, 0, 0.2);
  color:white;
  font-size: 25px;
}

.tabla-precios tr:nth-child(even) {
  background-color: rgba(255, 255, 255, 0.05);
}

.tabla-precios td {
  vertical-align: top;
}

/* Animación zoom */
@keyframes zoomIn {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* Clase activa que dispara el zoom */
.tabla-precios.activo {
  animation: zoomIn 1.5s ease forwards;
}



