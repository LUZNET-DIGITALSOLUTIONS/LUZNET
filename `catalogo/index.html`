  font-family: 'Shadows Into Light';
  margin: 10px;
  padding: 10px 20px;           /* espacio interno tipo botón */
  border: 1px solid white;    /* borde dorado */
  border-radius: 30px;          /* forma ovalada */
  background-color: transparent;
  box-shadow: 
    0 0 8px solid white,
    0 0 16px solid white; 
  cursor: pointer;

  /* Animación pulsante infinita */
  animation: zoomPulse 2s infinite ease-in-out;
  transition: transform 0.3s, color 0.3s;
}

.hijo6 a:hover {
  transform: scale(1.4);        /* más grande al pasar el mouse */
  color: white;                 /* cambia a blanco */
  
}

/* Animación pulsante */
